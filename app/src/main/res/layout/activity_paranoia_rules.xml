<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F2FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:id="@+id/textViewRules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:text="Game Rules"
            android:textColor="#3F3A46"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- How to play -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How to play"
            android:textColor="#4A4453"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:text="The host starts as the 'answerer' and the player to their right is the 'partner in crime'. A question is shown only to them. They may discuss it, but the answerer gives the final answer. The chosen person must be someone from the group."
            android:textColor="#3F3A46"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="18dp"/>

        <!-- Reveal round -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reveal round"
            android:textColor="#4A4453"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:text="After revealing the name, press 'Reveal your fate'. A coin flip decides whether the question is revealed. If yes, the answerer shares it. If not, it stays secret. Then pass the device left and continue."
            android:textColor="#3F3A46"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="18dp"/>

        <!-- Add spice -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add some spice"
            android:textColor="#4A4453"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Why paranoia -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="#FFFFFF"
            android:lineSpacingExtra="4dp"
            android:padding="14dp"
            android:text="When answering, be vague or misleading. Hint around the question instead of being direct. This keeps others guessing and increases the paranoia."
            android:textColor="#3F3A46"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Why paranoia?"
            android:textColor="#4A4453"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:text="The mix of questions makes players overthink everything. Do they like me? Hate me? Think I'm weird or funny? That's what creates the paranoia."
            android:textColor="#3F3A46"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp"/>

        <!-- Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/buttonBackToMain"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/paranoia_button"
            android:text="Back to main"
            android:textColor="@color/paranoiaButtonTextColour"
            android:textSize="18sp"
            android:textStyle="bold"
            android:onClick="onClickBackToMain"/>

    </LinearLayout>
</ScrollView>