        android:fontFamily="serif"
        android:text="Button"
        app:layout_constraintBottom_toTopOf="@+id/buttonSB8"
        app:layout_constraintEnd_toStartOf="@+id/buttonSB6"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/buttonSB4"
        app:layout_constraintTop_toBottomOf="@+id/buttonSB2" />

    <Button
        android:id="@+id/buttonSB6"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
