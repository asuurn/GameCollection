        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="serif"
        android:text="Button"
        app:layout_constraintBottom_toTopOf="@+id/buttonSB11"
        app:layout_constraintEnd_toStartOf="@+id/buttonSB9"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/buttonSB7"
        app:layout_constraintTop_toBottomOf="@+id/buttonSB5" />

    <Button
        android:id="@+id/buttonSB9"
